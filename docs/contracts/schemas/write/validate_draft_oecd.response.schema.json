{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "validate_draft_oecd.response",
  "type": "object",
  "required": ["draft_id", "version_id", "summary", "results"],
  "properties": {
    "draft_id": {"type": "string"},
    "version_id": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["error_count", "warning_count", "ready_for_review", "score"],
      "properties": {
        "error_count": {"type": "integer"},
        "warning_count": {"type": "integer"},
        "ready_for_review": {"type": "boolean"},
        "score": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "status", "severity", "message"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "status": {"type": "string", "enum": ["pass", "fail"]},
          "severity": {"type": "string", "enum": ["error", "warning"]},
          "message": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
