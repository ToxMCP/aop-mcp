{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "export_draft_replay_package.response",
  "type": "object",
  "required": [
    "package_schema_version",
    "generated_at",
    "runtime_manifest",
    "draft_id",
    "version_id",
    "draft_snapshot",
    "draft_integrity",
    "external_support",
    "saved_artifact",
    "audit_records",
    "limitations",
    "package_sha256"
  ],
  "properties": {
    "package_schema_version": {"type": "string", "const": "draft-replay-package.v1"},
    "generated_at": {"type": "string"},
    "runtime_manifest": {"$ref": "#/$defs/runtime_manifest"},
    "draft_id": {"type": "string"},
    "version_id": {"type": "string"},
    "draft_snapshot": {
      "type": "object",
      "required": ["draft", "version", "graph", "diff_summary"],
      "properties": {
        "draft": {
          "type": "object",
          "required": [
            "draft_id",
            "title",
            "status",
            "created_at",
            "updated_at",
            "tags",
            "version_count"
          ],
          "properties": {
            "draft_id": {"type": "string"},
            "title": {"type": "string"},
            "status": {"type": "string"},
            "created_at": {"type": "string"},
            "updated_at": {"type": "string"},
            "tags": {"type": "array", "items": {"type": "string"}},
            "version_count": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        },
        "version": {
          "type": "object",
          "required": [
            "version_id",
            "author",
            "summary",
            "created_at",
            "provenance",
            "checksum",
            "previous_checksum",
            "checksum_algorithm",
            "provenance_checksum",
            "provenance_checksum_algorithm",
            "signatures"
          ],
          "properties": {
            "version_id": {"type": "string"},
            "author": {"type": "string"},
            "summary": {"type": "string"},
            "created_at": {"type": "string"},
            "provenance": {"type": "object", "additionalProperties": true},
            "checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "previous_checksum": {"type": "string", "pattern": "^(|[a-f0-9]{64})$"},
            "checksum_algorithm": {"type": "string", "const": "sha256-v1"},
            "provenance_checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "provenance_checksum_algorithm": {"type": "string", "const": "sha256-v1"},
            "signatures": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "signer_user_id",
                  "signature_meaning",
                  "timestamp_utc",
                  "content_hash",
                  "signature_value",
                  "cert_chain"
                ],
                "properties": {
                  "signer_user_id": {"type": "string"},
                  "signature_meaning": {
                    "type": "string",
                    "enum": ["authored", "reviewed", "approved", "rejected"]
                  },
                  "timestamp_utc": {"type": "string"},
                  "content_hash": {"type": "string"},
                  "signature_value": {"type": "string"},
                  "cert_chain": {"type": "array", "items": {"type": "string"}}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "graph": {
          "type": "object",
          "required": ["entity_count", "relationship_count", "entities", "relationships"],
          "properties": {
            "entity_count": {"type": "integer", "minimum": 0},
            "relationship_count": {"type": "integer", "minimum": 0},
            "entities": {
              "type": "array",
              "items": {"$ref": "#/$defs/graph_entity"}
            },
            "relationships": {
              "type": "array",
              "items": {"$ref": "#/$defs/graph_relationship"}
            }
          },
          "additionalProperties": false
        },
        "diff_summary": {
          "type": "object",
          "required": [
            "added_entity_count",
            "removed_entity_count",
            "updated_entity_count",
            "added_relationship_count",
            "removed_relationship_count",
            "updated_relationship_count"
          ],
          "properties": {
            "added_entity_count": {"type": "integer", "minimum": 0},
            "removed_entity_count": {"type": "integer", "minimum": 0},
            "updated_entity_count": {"type": "integer", "minimum": 0},
            "added_relationship_count": {"type": "integer", "minimum": 0},
            "removed_relationship_count": {"type": "integer", "minimum": 0},
            "updated_relationship_count": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "draft_integrity": {
      "type": "object",
      "required": ["audit_chain", "provenance", "overall", "selected_version"],
      "properties": {
        "audit_chain": {"type": "boolean"},
        "provenance": {"type": "boolean"},
        "overall": {"type": "boolean"},
        "selected_version": {"$ref": "#/$defs/draft_version_integrity"}
      },
      "additionalProperties": false
    },
    "external_support": {"type": "object", "additionalProperties": true},
    "saved_artifact": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": [
            "filename",
            "path",
            "relative_path",
            "format",
            "artifact_profile",
            "sha256",
            "artifact_integrity",
            "draft_version_integrity",
            "integrity_check",
            "metadata_available"
          ],
          "properties": {
            "filename": {"type": "string"},
            "path": {"type": "string"},
            "relative_path": {"type": "string"},
            "format": {"type": "string", "enum": ["markdown", "json"]},
            "artifact_profile": {"type": "string", "enum": ["review", "publication"]},
            "draft_id": {"type": ["string", "null"]},
            "version_id": {"type": ["string", "null"]},
            "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "artifact_integrity": {"type": "object", "additionalProperties": true},
            "draft_version_integrity": {
              "anyOf": [
                {"type": "null"},
                {"$ref": "#/$defs/draft_version_integrity"}
              ]
            },
            "integrity_check": {"type": "object", "additionalProperties": true},
            "metadata_available": {"type": "boolean"}
          },
          "additionalProperties": true
        }
      ]
    },
    "audit_records": {
      "type": "object",
      "required": [
        "scope",
        "included",
        "limit",
        "included_record_count",
        "persistence",
        "records"
      ],
      "properties": {
        "scope": {"type": "string", "const": "process_local_recent_records"},
        "included": {"type": "boolean"},
        "limit": {"type": "integer", "minimum": 0, "maximum": 100},
        "included_record_count": {"type": "integer", "minimum": 0},
        "persistence": {
          "type": "object",
          "required": ["enabled", "path", "last_error", "chain"],
          "properties": {
            "enabled": {"type": "boolean"},
            "path": {"type": ["string", "null"]},
            "last_error": {"type": ["string", "null"]},
            "chain": {
              "type": "object",
              "required": [
                "algorithm",
                "record_count",
                "head_record_hash",
                "verified",
                "verification_error"
              ],
              "properties": {
                "algorithm": {"type": "string", "const": "sha256-json-v1"},
                "record_count": {"type": "integer", "minimum": 0},
                "head_record_hash": {
                  "type": ["string", "null"],
                  "pattern": "^[a-f0-9]{64}$"
                },
                "verified": {"type": ["boolean", "null"]},
                "verification_error": {"type": ["string", "null"]}
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "records": {
          "type": "array",
          "items": {"$ref": "#/$defs/tool_call_audit_record"}
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "package_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "graph_entity": {
      "type": "object",
      "required": ["identifier", "type", "attributes"],
      "properties": {
        "identifier": {"type": "string"},
        "type": {"type": "string"},
        "attributes": {"type": "object", "additionalProperties": true}
      },
      "additionalProperties": false
    },
    "graph_relationship": {
      "type": "object",
      "required": ["identifier", "source", "target", "type", "attributes"],
      "properties": {
        "identifier": {"type": "string"},
        "source": {"type": "string"},
        "target": {"type": "string"},
        "type": {"type": "string"},
        "attributes": {"type": "object", "additionalProperties": true}
      },
      "additionalProperties": false
    },
    "draft_version_integrity": {
      "type": "object",
      "required": [
        "checksum_algorithm",
        "graph_sha256",
        "previous_graph_sha256",
        "provenance_checksum_algorithm",
        "provenance_sha256"
      ],
      "properties": {
        "checksum_algorithm": {"type": "string", "const": "sha256-v1"},
        "graph_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "previous_graph_sha256": {"type": "string", "pattern": "^(|[a-f0-9]{64})$"},
        "provenance_checksum_algorithm": {"type": "string", "const": "sha256-v1"},
        "provenance_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "runtime_manifest": {
      "type": "object",
      "required": [
        "manifest_schema_version",
        "server",
        "runtime",
        "configuration",
        "contracts",
        "tool_registry",
        "source_control"
      ],
      "properties": {
        "manifest_schema_version": {
          "type": "string",
          "const": "aop-mcp-runtime-manifest.v1"
        },
        "server": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": {"type": "string"},
            "version": {"type": "string"}
          },
          "additionalProperties": false
        },
        "runtime": {
          "type": "object",
          "required": [
            "python_version",
            "python_implementation",
            "python_executable",
            "platform"
          ],
          "properties": {
            "python_version": {"type": "string"},
            "python_implementation": {"type": "string"},
            "python_executable": {"type": "string"},
            "platform": {"type": "string"}
          },
          "additionalProperties": false
        },
        "configuration": {
          "type": "object",
          "required": [
            "environment",
            "auth_mode",
            "auth_bearer_token_configured",
            "auth_bearer_scope_count",
            "allowed_origin_count",
            "fixture_fallback_enabled",
            "audit_log_enabled",
            "artifact_output_dir_configured",
            "comptox_api_key_configured",
            "max_request_bytes",
            "is_production",
            "allow_unauthenticated_production"
          ],
          "properties": {
            "environment": {"type": "string"},
            "auth_mode": {"type": "string", "enum": ["disabled", "bearer"]},
            "auth_bearer_token_configured": {"type": "boolean"},
            "auth_bearer_scope_count": {"type": "integer", "minimum": 0},
            "allowed_origin_count": {"type": "integer", "minimum": 0},
            "fixture_fallback_enabled": {"type": "boolean"},
            "audit_log_enabled": {"type": "boolean"},
            "artifact_output_dir_configured": {"type": "boolean"},
            "comptox_api_key_configured": {"type": "boolean"},
            "max_request_bytes": {"type": "integer", "minimum": 1},
            "is_production": {"type": "boolean"},
            "allow_unauthenticated_production": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "contracts": {
          "type": "object",
          "required": [
            "schema_root",
            "schema_count",
            "schema_root_sha256",
            "tracked_response_schemas"
          ],
          "properties": {
            "schema_root": {"type": "string", "const": "docs/contracts/schemas"},
            "schema_count": {"type": "integer", "minimum": 0},
            "schema_root_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "tracked_response_schemas": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "sha256"],
                "properties": {
                  "path": {"type": "string"},
                  "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "tool_registry": {
          "type": "object",
          "required": ["tool_count", "tool_names", "tool_catalog_sha256"],
          "properties": {
            "tool_count": {"type": "integer", "minimum": 0},
            "tool_names": {"type": "array", "items": {"type": "string"}},
            "tool_catalog_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          },
          "additionalProperties": false
        },
        "source_control": {
          "type": "object",
          "required": ["available", "commit", "source", "worktree_dirty"],
          "properties": {
            "available": {"type": "boolean"},
            "commit": {
              "type": ["string", "null"],
              "pattern": "^[a-f0-9]{40}$"
            },
            "source": {"type": "string"},
            "worktree_dirty": {"type": "string", "const": "not_assessed"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "tool_call_audit_record": {
      "type": "object",
      "required": [
        "call_id",
        "tool_name",
        "started_at",
        "finished_at",
        "duration_ms",
        "status",
        "argument_keys",
        "request_hash",
        "response_hash",
        "output_schema_title",
        "output_schema_hash",
        "output_validation_status",
        "risk_class",
        "required_scopes",
        "granted_scopes",
        "requires_confirmation",
        "confirmation_provided",
        "policy_status",
        "error_type",
        "error_message"
      ],
      "properties": {
        "call_id": {"type": "string"},
        "tool_name": {"type": "string"},
        "started_at": {"type": "string"},
        "finished_at": {"type": "string"},
        "duration_ms": {"type": "number"},
        "status": {"type": "string"},
        "argument_keys": {"type": "array", "items": {"type": "string"}},
        "request_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "response_hash": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "output_schema_title": {"type": ["string", "null"]},
        "output_schema_hash": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "output_validation_status": {"type": "string"},
        "risk_class": {"type": ["string", "null"]},
        "required_scopes": {"type": "array", "items": {"type": "string"}},
        "granted_scopes": {"type": "array", "items": {"type": "string"}},
        "requires_confirmation": {"type": ["boolean", "null"]},
        "confirmation_provided": {"type": "boolean"},
        "policy_status": {"type": "string"},
        "error_type": {"type": ["string", "null"]},
        "error_message": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
