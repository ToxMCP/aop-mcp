{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "list_saved_draft_review_artifacts.response",
  "type": "object",
  "required": ["results", "diagnostics"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "filename",
          "path",
          "relative_path",
          "output_directory",
          "format",
          "artifact_profile",
          "bytes_written",
          "sha256",
          "artifact_integrity",
          "draft_version_integrity",
          "integrity_check",
          "saved_at",
          "metadata_available",
          "bundle_summary"
        ],
        "properties": {
          "filename": {"type": "string"},
          "path": {"type": "string"},
          "relative_path": {"type": "string"},
          "output_directory": {"type": "string"},
          "format": {"type": "string", "enum": ["markdown", "json"]},
          "artifact_profile": {"type": "string", "enum": ["review", "publication"]},
          "draft_id": {"type": ["string", "null"]},
          "version_id": {"type": ["string", "null"]},
          "bytes_written": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "artifact_integrity": {
            "type": "object",
            "required": ["algorithm", "content_sha256", "metadata_sha256"],
            "properties": {
              "algorithm": {"type": "string", "const": "sha256-v1"},
              "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "metadata_sha256": {
                "type": ["string", "null"],
                "pattern": "^[a-f0-9]{64}$"
              }
            },
            "additionalProperties": false
          },
          "draft_version_integrity": {
            "type": ["object", "null"],
            "required": [
              "checksum_algorithm",
              "graph_sha256",
              "previous_graph_sha256",
              "provenance_checksum_algorithm",
              "provenance_sha256"
            ],
            "properties": {
              "checksum_algorithm": {"type": "string", "const": "sha256-v1"},
              "graph_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "previous_graph_sha256": {"type": "string", "pattern": "^(|[a-f0-9]{64})$"},
              "provenance_checksum_algorithm": {"type": "string", "const": "sha256-v1"},
              "provenance_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            },
            "additionalProperties": false
          },
          "integrity_check": {
            "type": "object",
            "required": [
              "overall_status",
              "content_status",
              "metadata_status",
              "content_sha256_actual",
              "content_sha256_expected",
              "metadata_sha256_actual",
              "metadata_sha256_expected",
              "messages"
            ],
            "properties": {
              "overall_status": {
                "type": "string",
                "enum": ["verified", "failed", "not_verifiable"]
              },
              "content_status": {
                "type": "string",
                "enum": ["verified", "failed", "not_verifiable"]
              },
              "metadata_status": {
                "type": "string",
                "enum": ["verified", "failed", "not_verifiable"]
              },
              "content_sha256_actual": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "content_sha256_expected": {"type": ["string", "null"]},
              "metadata_sha256_actual": {
                "type": ["string", "null"],
                "pattern": "^[a-f0-9]{64}$"
              },
              "metadata_sha256_expected": {"type": ["string", "null"]},
              "messages": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "additionalProperties": false
          },
          "saved_at": {"type": "string"},
          "metadata_available": {"type": "boolean"},
          "metadata_path": {"type": ["string", "null"]},
          "bundle_summary": {
            "type": ["object", "null"],
            "required": [
              "ready_for_review",
              "validator_error_count",
              "validator_warning_count",
              "assay_cutoff_assessable_relationship_count",
              "assay_cutoff_discordant_relationship_count",
              "chemical_trace_included",
              "traced_key_event_count",
              "active_key_event_count",
              "total_gap_count",
              "blocking_gap_count",
              "advisory_gap_count"
            ],
            "properties": {
              "ready_for_review": {"type": "boolean"},
              "validator_error_count": {"type": "integer"},
              "validator_warning_count": {"type": "integer"},
              "assay_cutoff_assessable_relationship_count": {"type": "integer"},
              "assay_cutoff_discordant_relationship_count": {"type": "integer"},
              "chemical_trace_included": {"type": "boolean"},
              "traced_key_event_count": {"type": "integer"},
              "active_key_event_count": {"type": "integer"},
              "total_gap_count": {"type": "integer"},
              "blocking_gap_count": {"type": "integer"},
              "advisory_gap_count": {"type": "integer"}
            },
            "additionalProperties": false
          },
          "evidence_gap_summary": {
            "type": ["object", "null"],
            "required": [
              "ready_for_review",
              "total_gap_count",
              "blocking_gap_count",
              "advisory_gap_count",
              "global_gap_count",
              "key_event_gap_count",
              "relationship_gap_count",
              "stressor_gap_count",
              "assay_mapping_gap_count"
            ],
            "properties": {
              "ready_for_review": {"type": "boolean"},
              "total_gap_count": {"type": "integer"},
              "blocking_gap_count": {"type": "integer"},
              "advisory_gap_count": {"type": "integer"},
              "global_gap_count": {"type": "integer"},
              "key_event_gap_count": {"type": "integer"},
              "relationship_gap_count": {"type": "integer"},
              "stressor_gap_count": {"type": "integer"},
              "assay_mapping_gap_count": {"type": "integer"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "diagnostics": {
      "type": "object",
      "required": [
        "artifact_root_directory",
        "scanned_directory",
        "scanned_artifact_count",
        "returned_artifact_count",
        "missing_metadata_count",
        "warnings"
      ],
      "properties": {
        "artifact_root_directory": {"type": "string"},
        "scanned_directory": {"type": "string"},
        "scanned_artifact_count": {"type": "integer"},
        "returned_artifact_count": {"type": "integer"},
        "missing_metadata_count": {"type": "integer"},
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
